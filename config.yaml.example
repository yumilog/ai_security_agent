# AI Security Agent config (optional)
# Copy to config.yaml and fill in. All agents use config.auth for every request.

target: https://example.com

auth:
  # Cookie: all requests send these cookies
  cookie:
    session: "your-session-cookie-value"
  # Or use JWT (sent as Authorization: Bearer <token>)
  # jwt: "eyJ..."
  # Or raw Authorization header (Bearer token or custom)
  # authorization: "Bearer xxx"
  # Or use header block for Authorization
  # header:
  #   Authorization: "Bearer YOUR_TOKEN"

  # User switching: two sessions (Account A, Account B) for broken access control testing
  # Same URL requested with A and B; if response differs -> candidate
  user_switching:
    - name: "A"
      cookie:
        session: "session_account_a"
    - name: "B"
      cookie:
        session: "session_account_b"

# Max requests per second (0 = no limit). Suggested: 10 (safe) / 50 (staging) / 100 (fast; may hit WAF)
rate_limit: 10

# Allowed domains (empty = target origin only)
scope:
  - example.com

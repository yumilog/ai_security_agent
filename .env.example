# Optional: LLM provider ("openai" or "anthropic")
# LLM_PROVIDER=openai

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic (if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: model overrides
# LLM_MODEL_OPENAI=gpt-4o-mini
# LLM_MODEL_ANTHROPIC=claude-3-haiku-20240307

# Optional: report output directory
# REPORT_DIR=reports
